{
  "name": "noschen",
  "version": "1.0.0",
  "description": "AI-Powered Research Note-Taking App",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "tsc && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "package": "npm run build && node scripts/nest-llama-deps.js && electron-builder && node scripts/nest-llama-deps.js --cleanup",
    "download-model": "node scripts/download-model.js",
    "download-model:phi3": "node scripts/download-model.js --model=phi-3-mini-128k",
    "download-compressor": "node scripts/download-compressor-model.js",
    "generate-icon": "bash scripts/generate-icon.sh",
    "generate-sample-notes": "node scripts/generate-sample-notes.js"
  },
  "overrides": {
    "tar": ">=7.5.7",
    "glob": "^10.0.0",
    "axios": ">=1.13.5",
    "form-data": ">=4.0.6"
  },
  "keywords": [
    "note-taking",
    "research",
    "ai",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@atjsh/llmlingua-2": "^2.0.3",
    "@huggingface/transformers": "^4.2.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-highlight": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.469.0",
    "node-llama-cpp": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.0"
  },
  "build": {
    "appId": "com.noschen.app",
    "productName": "Noschen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "models/**/*"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "models/**/*",
      "node_modules/node-llama-cpp/**/*",
      "node_modules/@node-llama-cpp/**/*",
      "node_modules/@atjsh/llmlingua-2/**/*",
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/@tensorflow/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/js-tiktoken/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleName": "Noschen",
        "CFBundleDisplayName": "Noschen"
      }
    },
    "dmg": {
      "title": "Noschen",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
